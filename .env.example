# ── OpenAI (chat + extraction + notebook-photo OCR + embeddings) ─────────────
OPENAI_API_KEY=
# Chat model must accept image input; embeddings run at 1024 dimensions to
# match the database VECTOR(1024) columns.
OPENAI_CHAT_MODEL=gpt-5.1
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── AWS (deployment layer: EC2 agent runtime + S3 media storage) ─────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET=

# ── Database (CockroachDB Cloud — Postgres wire protocol) ────────────────────
# From the CockroachDB Cloud console: Connect → General connection string.
DATABASE_URL=postgresql://user:password@cluster-host:26257/kata?sslmode=verify-full

# ── API server ────────────────────────────────────────────────────────────────
PORT=8787
# Comma-separated origins allowed to call the API (the dashboard)
CORS_ORIGINS=http://localhost:3000
# Random 32+ char secret used to sign dashboard session tokens
SESSION_SECRET=

# ── WhatsApp (Baileys) ────────────────────────────────────────────────────────
# Directory where the Baileys auth state is persisted (gitignored)
WA_AUTH_DIR=./auth-state

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8787
