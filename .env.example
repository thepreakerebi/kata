# ── Qwen Cloud (Alibaba Cloud Model Studio, international endpoint) ──────────
# Get a key: https://bit.ly/qwencloud-getapi
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Database (Postgres + pgvector) ────────────────────────────────────────────
DATABASE_URL=postgres://kata:kata@localhost:5432/kata

# ── API server ────────────────────────────────────────────────────────────────
PORT=8787
# Comma-separated origins allowed to call the API (the dashboard)
CORS_ORIGINS=http://localhost:3000
# Random 32+ char secret used to sign dashboard session tokens
SESSION_SECRET=

# ── WhatsApp (Baileys) ────────────────────────────────────────────────────────
# Directory where the Baileys auth state is persisted (gitignored)
WA_AUTH_DIR=./auth-state

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8787
