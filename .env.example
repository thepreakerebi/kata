# ── Amazon Bedrock (models: chat, extraction, OCR, embeddings) ───────────────
# Credentials resolve via the standard AWS chain (env vars locally, task role
# on ECS). Locally, set these two or use an AWS_PROFILE instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Any Bedrock chat model with image input works (Converse API). Anthropic
# models require a paid-plan account (Marketplace); Nova works on free plan.
BEDROCK_CHAT_MODEL_ID=eu.amazon.nova-pro-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Amazon S3 (WhatsApp media + notebook photos) ─────────────────────────────
S3_BUCKET=

# ── Database (CockroachDB Cloud — Postgres wire protocol) ────────────────────
# From the CockroachDB Cloud console: Connect → General connection string.
DATABASE_URL=postgresql://user:password@cluster-host:26257/kata?sslmode=verify-full

# ── API server ────────────────────────────────────────────────────────────────
PORT=8787
# Comma-separated origins allowed to call the API (the dashboard)
CORS_ORIGINS=http://localhost:3000
# Random 32+ char secret used to sign dashboard session tokens
SESSION_SECRET=

# ── WhatsApp (Baileys) ────────────────────────────────────────────────────────
# Directory where the Baileys auth state is persisted (gitignored)
WA_AUTH_DIR=./auth-state

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8787
